<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <PackageId>navlyn</PackageId>
    <ToolCommandName>navlyn</ToolCommandName>
    <Version>0.6.0</Version>
    <Authors>furbon.tech</Authors>
    <Description>Read-only C#/.NET semantic evidence CLI that helps coding agents avoid wrong-symbol edits.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>navlyn-icon.png</PackageIcon>
    <PackageTags>dotnet-tool;csharp;dotnet;roslyn;cli;mcp;ai-agents;semantic-code-navigation;automation</PackageTags>
    <RepositoryUrl>https://github.com/furbon/navlyn</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/furbon/navlyn</PackageProjectUrl>
    <PackageReleaseNotes>0.6.0 strengthens the C# agent preflight loop with first-10-minutes onboarding, wrong-symbol edit guidance, expanded eval and performance documentation, stabilized multi-target test execution, synchronized contract docs, and refreshed package/release identity.</PackageReleaseNotes>
    <Copyright>Copyright (c) 2026 furbon.tech</Copyright>
    <NeutralLanguage>en-US</NeutralLanguage>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\assets\navlyn-icon.png" Pack="true" PackagePath="\" />
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\README_ja.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Navlyn.CommandLine\Navlyn.CommandLine.csproj" />
  </ItemGroup>

</Project>
