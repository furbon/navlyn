{
  "customizations": {
    "vscode": {
      "mcp": {
        "servers": {
          "navlyn": {
            "type": "stdio",
            "command": "navlyn-mcp",
            "args": [
              "--workspace",
              "${workspaceFolder}/YourRepo.slnx"
            ],
            "cwd": "${workspaceFolder}"
          }
        }
      }
    }
  }
}
